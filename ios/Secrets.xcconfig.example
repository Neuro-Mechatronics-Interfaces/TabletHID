// Copy this file to Secrets.xcconfig and fill in your base URL.
// Secrets.xcconfig is listed in .gitignore and must not be committed.
//
// When COMMUNITY_API_BASE_URL is blank the community feature is disabled
// (every API call returns a "not configured" error).
//
// xcconfig treats // as a comment marker, so write https URLs as:
// COMMUNITY_API_BASE_URL = https:/$()/example.com

COMMUNITY_API_BASE_URL =
