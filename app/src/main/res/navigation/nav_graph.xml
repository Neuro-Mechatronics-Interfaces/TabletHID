<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.tablet.hid.ui.onboarding.OnboardingFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_onboarding">

        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.tablet.hid.ui.home.HomeFragment"
        android:label="@string/label_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_tutorialFragment"
            app:destination="@id/tutorialFragment" />

        <!-- Direct entry when already connected — skips Tutorial -->
        <action
            android:id="@+id/action_home_to_touchMouse"
            app:destination="@id/touchMouseFragment"
            app:popUpTo="@id/homeFragment" />

        <action
            android:id="@+id/action_home_to_gamepad"
            app:destination="@id/gamepadFragment"
            app:popUpTo="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/tutorialFragment"
        android:name="com.tablet.hid.ui.tutorial.TutorialFragment"
        android:label="@string/label_tutorial"
        tools:layout="@layout/fragment_tutorial">

        <argument
            android:name="mode"
            app:argType="com.tablet.hid.model.DeviceMode" />

        <action
            android:id="@+id/action_tutorial_to_touchMouse"
            app:destination="@id/touchMouseFragment"
            app:popUpTo="@id/homeFragment" />

        <action
            android:id="@+id/action_tutorial_to_gamepad"
            app:destination="@id/gamepadFragment"
            app:popUpTo="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/touchMouseFragment"
        android:name="com.tablet.hid.ui.touchmouse.TouchMouseFragment"
        android:label="@string/label_touch_mouse"
        tools:layout="@layout/fragment_touch_mouse">

        <action
            android:id="@+id/action_touchMouse_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/gamepadFragment"
        android:name="com.tablet.hid.ui.gamepad.GamepadFragment"
        android:label="@string/label_gamepad"
        tools:layout="@layout/fragment_gamepad">

        <action
            android:id="@+id/action_gamepad_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.tablet.hid.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <action
        android:id="@+id/action_global_to_settings"
        app:destination="@id/settingsFragment" />

</navigation>
