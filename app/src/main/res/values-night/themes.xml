<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TabletHID" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
        <item name="forgetButtonStyle">@style/Widget.App.Button.Forget</item>
    </style>

    <style name="Theme.TabletHID" parent="Base.Theme.TabletHID">
        <item name="colorError">#F2B8B5</item>
    </style>

    <style name="Theme.TabletHID.HighContrast" parent="Base.Theme.TabletHID">
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/high_contrast_accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="colorOutline">@color/white</item>
    </style>
</resources>
