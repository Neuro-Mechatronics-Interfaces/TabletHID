<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bottom_sheet_handle" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="20dp" />

            <!-- ── Mode selector ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_mode"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btnTouch"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_mode_touch" />

                <Button
                    android:id="@+id/btnMouse"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_mode_mouse" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ── Mouse-mode settings (GONE in Touch mode) ────────── -->
            <LinearLayout
                android:id="@+id/groupMouseSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Sensitivity -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_sensitivity"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSensitivity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="1"
                        android:valueTo="10"
                        android:stepSize="1"
                        android:value="5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/labelSensValue"
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:gravity="center" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" />

                <!-- ══════════════════ LEFT BUTTON ══════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/circle_left" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/config_left_button"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Left button expanded config -->
                <LinearLayout
                    android:id="@+id/configLeft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/config_zone_type"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleLeftZone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <Button
                            android:id="@+id/btnLeftStatic"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_static" />

                        <Button
                            android:id="@+id/btnLeftDynamic"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_dynamic" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/config_click_behavior"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleLeftBehavior"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <Button
                            android:id="@+id/btnLeftMomentary"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_momentary" />

                        <Button
                            android:id="@+id/btnLeftLatching"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_latching" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Static zone: Set Zone button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetLeftZone"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/config_set_zone" />

                    <!-- Dynamic zone: offset + size sliders -->
                    <LinearLayout
                        android:id="@+id/groupDynamicLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_offset_x"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderLeftOffsetX"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="-1"
                                android:valueTo="1"
                                android:stepSize="0.05"
                                android:value="0.15" />
                            <TextView
                                android:id="@+id/labelLeftOffsetX"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text="+0.15"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_offset_y"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderLeftOffsetY"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="-1"
                                android:valueTo="1"
                                android:stepSize="0.05"
                                android:value="0" />
                            <TextView
                                android:id="@+id/labelLeftOffsetY"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text=" 0.00"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_zone_size"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderLeftRadius"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0.03"
                                android:valueTo="0.20"
                                android:stepSize="0.01"
                                android:value="0.07" />
                            <TextView
                                android:id="@+id/labelLeftRadius"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text="0.07"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" />

                <!-- ══════════════════ RIGHT BUTTON ═════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/circle_right" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/config_right_button"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchRight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Right button expanded config -->
                <LinearLayout
                    android:id="@+id/configRight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/config_zone_type"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleRightZone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <Button
                            android:id="@+id/btnRightStatic"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_static" />

                        <Button
                            android:id="@+id/btnRightDynamic"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_dynamic" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/config_click_behavior"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleRightBehavior"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <Button
                            android:id="@+id/btnRightMomentary"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_momentary" />

                        <Button
                            android:id="@+id/btnRightLatching"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/config_latching" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Static zone: Set Zone button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetRightZone"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/config_set_zone" />

                    <!-- Dynamic zone: offset + size sliders -->
                    <LinearLayout
                        android:id="@+id/groupDynamicRight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_offset_x"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderRightOffsetX"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="-1"
                                android:valueTo="1"
                                android:stepSize="0.05"
                                android:value="-0.15" />
                            <TextView
                                android:id="@+id/labelRightOffsetX"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text="-0.15"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_offset_y"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderRightOffsetY"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="-1"
                                android:valueTo="1"
                                android:stepSize="0.05"
                                android:value="0" />
                            <TextView
                                android:id="@+id/labelRightOffsetY"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text=" 0.00"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/config_zone_size"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderRightRadius"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0.03"
                                android:valueTo="0.20"
                                android:stepSize="0.01"
                                android:value="0.07" />
                            <TextView
                                android:id="@+id/labelRightRadius"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:text="0.07"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:gravity="end" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calibration"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAutoCalibrate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/config_auto_calibrate" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Place three fingers in sequence to set comfortable click positions automatically. Sets both buttons to Dynamic mode."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
            <!-- end groupMouseSettings -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
