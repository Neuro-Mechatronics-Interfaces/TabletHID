<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Bluetooth ──────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Bluetooth"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Device name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDeviceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Hosts will see this name when pairing. Changes apply the next time you prepare a new Bluetooth connection."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAutoReconnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/setting_auto_reconnect" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Appearance ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Appearance"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="?attr/colorPrimary" />

        <RadioGroup
            android:id="@+id/radioGroupAppearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioAppearanceSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orientation_system" />

            <RadioButton
                android:id="@+id/radioAppearanceLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light" />

            <RadioButton
                android:id="@+id/radioAppearanceDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark" />

        </RadioGroup>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchLargeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Large Text" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchHighContrast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="High Contrast" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Session Logging ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Session Logging"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchSessionLogging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Enable local session logging" />

        <TextView
            android:id="@+id/textLoggingPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Orientation Lock ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/orientation_lock"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="?attr/colorPrimary" />

        <RadioGroup
            android:id="@+id/radioGroupOrientation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioOrientationSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orientation_system" />

            <RadioButton
                android:id="@+id/radioOrientationPortrait"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orientation_portrait" />

            <RadioButton
                android:id="@+id/radioOrientationLandscape"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orientation_landscape" />

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/orientation_lock_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <!-- ── Advanced ───────────────────────────────────────────────────── -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchScreenPinning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_screen_pinning" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="When enabled, entering Gamepad or Touch Mouse mode pins the app to the screen. Long-press Back + Recent to unpin."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <!-- ── Save button ────────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
