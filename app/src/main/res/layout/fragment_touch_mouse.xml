<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Thin status bar at the very top -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="#CC1a1a1a"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- LED status indicator -->
        <View
            android:id="@+id/ledStatus"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/shape_led"
            android:backgroundTint="#F44336" />

        <TextView
            android:id="@+id/textConnStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/status_disconnected"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />

        <!-- Orientation lock button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrientationLock"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/orientation_lock"
            app:icon="@drawable/ic_orientation_auto"
            app:iconSize="24dp"
            app:iconTint="@android:color/white" />

        <!-- Shortcut launcher panel toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShortcutPanel"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Keyboard shortcuts"
            android:visibility="gone"
            app:icon="@drawable/ic_keyboard"
            app:iconSize="24dp"
            app:iconTint="@android:color/white" />

        <!-- Settings (config drawer) button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/config_title"
            app:icon="@drawable/ic_settings"
            app:iconSize="28dp"
            app:iconTint="@android:color/white" />

    </LinearLayout>

    <!-- Main touch surface — TouchZoneOverlayView handles both rendering and touch events -->
    <com.tablet.hid.ui.touchmouse.TouchZoneOverlayView
        android:id="@+id/touchZoneOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0A0A0A"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar" />

    <!-- Hint text centred in the touch surface — pointer events pass through -->
    <TextView
        android:id="@+id/textHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/touch_mouse_hint"
        android:textColor="#33FFFFFF"
        android:textSize="13sp"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:focusable="false"
        android:clickable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Full-canvas overlay for freely positionable macro buttons -->
    <FrameLayout
        android:id="@+id/macroOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Macro layout edit banner — visible only during macro layout editing -->
    <LinearLayout
        android:id="@+id/macroEditBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EE0D0D1A"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/macro_edit_layout_hint"
            android:textColor="#FFDD88"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMacroEditDone"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minHeight="36dp"
            android:text="Done" />

    </LinearLayout>

    <!-- Keyboard shortcut panel — right-side overlay, toggled by the keyboard button -->
    <LinearLayout
        android:id="@+id/shortcutPanel"
        android:layout_width="190dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#D91a1a1a"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/shortcutPanelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!--
        Zone-edit overlay panel — sits at the top of the surface area.
        Uses wrap_content height so it doesn't cover the whole screen,
        leaving the drawing area below free for touch capture by touchZoneOverlay.
    -->
    <LinearLayout
        android:id="@+id/zoneEditOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:background="#B3000000"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <TextView
            android:id="@+id/labelZoneEditHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/zone_edit_hint_left"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelEdit"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <!--
        Calibration overlay — shown during the dynamic-zone auto-calibration procedure.
        Structured identically to zoneEditOverlay so it stays above the touch surface.
    -->
    <LinearLayout
        android:id="@+id/calibrationOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:background="#B3000000"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <TextView
            android:id="@+id/labelCalibrationHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calibrate_hint_primary"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelCalibration"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@android:color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
