<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bottom_sheet_handle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="16dp"
            android:text="Gamepad Settings"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <!-- ── Button Settings ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Button Settings"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilButtonSelect"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="Select button">

            <AutoCompleteTextView
                android:id="@+id/spinnerButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchButtonEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:checked="true"
            android:text="Enable this control" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilButtonLabel"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="Custom label (leave blank for default)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etButtonLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="4dp"
            android:text="Click behavior"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleBehavior"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="12dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnMomentary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Momentary" />

            <Button
                android:id="@+id/btnLatching"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latching" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchTurbo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:text="Turbo (auto-repeat)" />

        <LinearLayout
            android:id="@+id/groupTurbo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/labelTurboDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Press duration: 50 ms"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderTurboDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:valueFrom="10"
                android:valueTo="500"
                android:stepSize="10" />

            <TextView
                android:id="@+id/labelTurboInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Repeat interval: 100 ms"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderTurboInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:valueFrom="50"
                android:valueTo="1000"
                android:stepSize="50" />
        </LinearLayout>

        <!-- ── Trigger Settings (LT/RT only) ────────────────────────── -->
        <LinearLayout
            android:id="@+id/groupTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/labelTriggerTravel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Trigger travel: 150 dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderTriggerTravel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:valueFrom="30"
                android:valueTo="300"
                android:stepSize="10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="4dp"
                android:text="Drag direction"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleTriggerAxis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <Button
                    android:id="@+id/btnAxisUp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▲" />

                <Button
                    android:id="@+id/btnAxisDown"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼" />

                <Button
                    android:id="@+id/btnAxisLeft"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◀" />

                <Button
                    android:id="@+id/btnAxisRight"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:background="?attr/colorOutline" />

        <!-- ── Joystick Settings ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Joystick Settings"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchSingleJoystickMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:text="Single joystick mode" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchSingleJoystickSideToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:text="Show side toggle on layout" />

        <TextView
            android:id="@+id/labelSingleJoystickOutputSide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="4dp"
            android:text="Single joystick output"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleSingleJoystickOutputSide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="12dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnSingleOutputLeft"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Left stick" />

            <Button
                android:id="@+id/btnSingleOutputRight"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Right stick" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchLeftEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:checked="true"
            android:text="Left Stick enabled" />

        <LinearLayout
            android:id="@+id/groupLeftJoystick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/labelLeftDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Deadzone: 8%"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderLeftDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:valueFrom="0"
                android:valueTo="30"
                android:stepSize="1" />

            <TextView
                android:id="@+id/labelLeftGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Gain: 1.0×"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderLeftGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:valueFrom="50"
                android:valueTo="300"
                android:stepSize="5" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchRightEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:checked="true"
            android:text="Right Stick enabled" />

        <LinearLayout
            android:id="@+id/groupRightJoystick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/labelRightDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Deadzone: 8%"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderRightDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:valueFrom="0"
                android:valueTo="30"
                android:stepSize="1" />

            <TextView
                android:id="@+id/labelRightGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="Gain: 1.0×"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderRightGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:valueFrom="50"
                android:valueTo="300"
                android:stepSize="5" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:background="?attr/colorOutline" />

        <!-- ── Layout editing ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Keyboard Macros"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleMacroDefaults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnMacroWindows"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Windows" />

            <Button
                android:id="@+id/btnMacroMac"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mac" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddMacroDefaults"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add defaults" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearMacros"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Clear macros" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddCustomMacro"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/macro_add_custom" />

        <LinearLayout
            android:id="@+id/macroList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Layout"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditLayout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="Edit Layout (drag / pinch to resize)" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetLayout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="4dp"
            android:text="Reset to defaults" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:background="?attr/colorOutline" />

        <!-- ── Haptic Feedback ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Haptic Feedback"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleVibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="12dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnVibOff"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off" />

            <Button
                android:id="@+id/btnVibLight"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light" />

            <Button
                android:id="@+id/btnVibMedium"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium" />

            <Button
                android:id="@+id/btnVibStrong"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Strong" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- ── DEV section (visible only when BuildConfig.DEV_MODE) ───── -->
        <LinearLayout
            android:id="@+id/groupDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="12dp"
                android:background="?attr/colorOutline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="4dp"
                android:text="Developer"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorError" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportConfig"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="4dp"
                android:text="Export Gamepad Config" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportAllConfigs"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:text="Export All Configs" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="ADB pull (USB debug):\nadb shell run-as com.tablet.hid\n  cp shared_prefs/*.xml /sdcard/\nadb pull /sdcard/"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:fontFamily="monospace"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
