<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- Status chip -->
    <com.google.android.material.chip.Chip
        android:id="@+id/chipStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_status_idle"
        app:chipBackgroundColor="?attr/colorSurfaceVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <!-- OS selector -->
    <RadioGroup
        android:id="@+id/radioGroupOs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipStatus">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioWindows"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutorial_tab_windows"
            android:checked="true" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioMacos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutorial_tab_macos"
            android:layout_marginStart="24dp" />
    </RadioGroup>

    <!-- Instructions — numbered step list, switches between Windows/macOS and mode -->
    <ScrollView
        android:id="@+id/scrollInstructions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnMakeDiscoverable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/radioGroupOs">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <!-- Reconnect column — shown only when a bonded device is detected -->
            <LinearLayout
                android:id="@+id/columnReconnect"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/labelReconnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_col_reconnect"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/instructionsListReconnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Vertical divider between columns -->
            <View
                android:id="@+id/columnDivider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?attr/colorOutlineVariant"
                android:visibility="gone"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <!-- Main / fresh-pair column -->
            <LinearLayout
                android:id="@+id/columnPair"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/labelPair"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_col_new_pair"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOutline"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/instructionsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Shown only when a matching bonded device is detected -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReconnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_reconnect"
        android:visibility="gone"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/btnMakeDiscoverable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMakeDiscoverable"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_make_discoverable"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnEnterMode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnterMode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_enter_mouse_mode"
        android:enabled="false"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
