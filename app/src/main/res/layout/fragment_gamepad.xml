<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:keepScreenOn="true">

    <!-- ── Status bar ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:background="#CC1a1a1a"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/ledStatus"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/shape_led"
            android:backgroundTint="#F44336" />

        <TextView
            android:id="@+id/textConnStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Disconnected"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Gamepad Settings"
            app:icon="@drawable/ic_settings"
            app:iconSize="28dp"
            app:iconTint="@android:color/white" />

    </LinearLayout>

    <!-- ── Top-left: LT / LB ─────────────────────────────────── -->
    <Button
        android:id="@+id/btnLt"
        android:layout_width="90dp"
        android:layout_height="44dp"
        android:text="LT"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnLb"
        android:layout_width="90dp"
        android:layout_height="44dp"
        android:text="LB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnLt"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp" />

    <!-- ── Top-right: RT / RB ────────────────────────────────── -->
    <Button
        android:id="@+id/btnRt"
        android:layout_width="90dp"
        android:layout_height="44dp"
        android:text="RT"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnRb"
        android:layout_width="90dp"
        android:layout_height="44dp"
        android:text="RB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnRt"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp" />

    <!-- ── Center-top: Back / Start (packed chain, centered) ─── -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="72dp"
        android:layout_height="40dp"
        android:text="Back"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="7sp"
        android:autoSizeMaxTextSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="72dp"
        android:layout_height="40dp"
        android:text="Start"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="7sp"
        android:autoSizeMaxTextSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp" />

    <!-- ── D-Pad (left side, vertical center) ───────────────── -->
    <Button
        android:id="@+id/dpadUp"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="▲"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/dpadLeft"
        app:layout_constraintStart_toStartOf="@id/dpadLeft"
        app:layout_constraintEnd_toEndOf="@id/dpadLeft" />

    <Button
        android:id="@+id/dpadLeft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="◀"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/leftJoystick"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/dpadRight"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="▶"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintTop_toTopOf="@id/dpadLeft"
        app:layout_constraintStart_toEndOf="@id/dpadLeft"
        android:layout_marginStart="4dp" />

    <Button
        android:id="@+id/dpadDown"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="▼"
        android:textColor="#FFFFFF"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/dpadLeft"
        app:layout_constraintStart_toStartOf="@id/dpadLeft"
        app:layout_constraintEnd_toEndOf="@id/dpadLeft"
        android:layout_marginTop="4dp" />

    <!-- ── Left joystick ─────────────────────────────────────── -->
    <com.tablet.hid.ui.gamepad.JoystickView
        android:id="@+id/leftJoystick"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp" />

    <!-- ── Right joystick ────────────────────────────────────── -->
    <com.tablet.hid.ui.gamepad.JoystickView
        android:id="@+id/rightJoystick"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp" />

    <!-- ── ABXY cluster (right side, vertical center) ─────────
         Y (top), X (left), B (right), A (bottom)              -->
    <Button
        android:id="@+id/btnY"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="Y"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F5C518"
        app:layout_constraintBottom_toTopOf="@id/btnX"
        app:layout_constraintEnd_toEndOf="@id/btnX"
        app:layout_constraintStart_toStartOf="@id/btnX" />

    <Button
        android:id="@+id/btnX"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="X"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3B82F6"
        app:layout_constraintBottom_toTopOf="@id/rightJoystick"
        app:layout_constraintEnd_toStartOf="@id/btnB"
        android:layout_marginBottom="4dp"
        android:layout_marginEnd="4dp" />

    <Button
        android:id="@+id/btnB"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="B"
        android:textColor="#FFFFFF"
        android:backgroundTint="#EF4444"
        app:layout_constraintTop_toTopOf="@id/btnX"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp" />

    <Button
        android:id="@+id/btnA"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="A"
        android:textColor="#FFFFFF"
        android:backgroundTint="#22C55E"
        app:layout_constraintTop_toBottomOf="@id/btnX"
        app:layout_constraintStart_toStartOf="@id/btnX"
        app:layout_constraintEnd_toEndOf="@id/btnX"
        android:layout_marginTop="4dp" />

    <!-- Edit mode banner — overlays top of screen, visible only during layout editing -->
    <LinearLayout
        android:id="@+id/editModeBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EE0D0D1A"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit — drag to move · pinch to resize (H/V independently)"
            android:textColor="#FFDD88"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditDone"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minHeight="36dp"
            android:text="Done" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
