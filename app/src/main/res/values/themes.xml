<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TabletHID" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorError">#B00020</item>
        <item name="forgetButtonStyle">@style/Widget.App.Button.Forget</item>
    </style>

    <style name="Theme.TabletHID" parent="Base.Theme.TabletHID" />

    <style name="Theme.TabletHID.HighContrast" parent="Base.Theme.TabletHID">
        <item name="colorError">#FF0000</item>
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/high_contrast_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorOutline">@color/black</item>
    </style>
</resources>
