    <!-- Windows pairing instructions (use <br> not \n — Html.fromHtml collapses bare newlines) -->
    <string name="instructions_windows_mouse"><b>1.</b> Tap <b>Make Discoverable</b> below.<br/><br/><b>2.</b> On your Windows PC open <b>Settings &#8594; Bluetooth &amp; devices &#8594; Add device</b>.<br/><br/><b>3.</b> Choose <b>Bluetooth</b> and wait for <b>TabletHID Mouse</b> to appear.<br/><br/><b>4.</b> Click it to pair — no PIN required.<br/><br/><b>5.</b> Once connected, tap <b>Enter Touch Mouse</b> below.</string>
    <string name="instructions_windows_gamepad"><b>1.</b> Tap <b>Make Discoverable</b> below.<br/><br/><b>2.</b> On your Windows PC open <b>Settings &#8594; Bluetooth &amp; devices &#8594; Add device</b>.<br/><br/><b>3.</b> Choose <b>Bluetooth</b> and wait for <b>TabletHID Gamepad</b> to appear.<br/><br/><b>4.</b> Click it to pair — no PIN required.<br/><br/><b>5.</b> Once connected, tap <b>Enter Gamepad</b> below.</string>

    <!-- macOS pairing instructions -->
    <string name="instructions_macos_mouse"><b>1.</b> Tap <b>Make Discoverable</b> below.<br/><br/><b>2.</b> On your Mac open <b>System Settings &#8594; Bluetooth</b>.<br/><br/><b>3.</b> Wait for <b>TabletHID Mouse</b> to appear in the device list.<br/><br/><b>4.</b> Click <b>Connect</b> — no PIN required.<br/><br/><b>5.</b> Once connected, tap <b>Enter Touch Mouse</b> below.</string>
    <string name="instructions_macos_gamepad"><b>1.</b> Tap <b>Make Discoverable</b> below.<br/><br/><b>2.</b> On your Mac open <b>System Settings &#8594; Bluetooth</b>.<br/><br/><b>3.</b> Wait for <b>TabletHID Gamepad</b> to appear in the device list.<br/><br/><b>4.</b> Click <b>Connect</b> — no PIN required.<br/><br/><b>5.</b> Once connected, tap <b>Enter Gamepad</b> below.</string>

