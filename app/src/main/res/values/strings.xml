    <!-- Pairing instruction steps — each item is one step; bold via escaped HTML tags -->
    <string-array name="instructions_windows_mouse">
        <item>Tap &lt;b&gt;Make Discoverable&lt;/b&gt; below.</item>
        <item>On your Windows PC, open &lt;b&gt;Settings → Bluetooth &amp; devices → Add device&lt;/b&gt;.</item>
        <item>Choose &lt;b&gt;Bluetooth&lt;/b&gt; and wait for &lt;b&gt;TabletHID&lt;/b&gt; to appear.</item>
        <item>Click it to pair — no PIN required.</item>
        <item>Once connected, tap &lt;b&gt;Enter Touch Mouse&lt;/b&gt; below.</item>
    </string-array>
    <string-array name="instructions_windows_gamepad">
        <item>Tap &lt;b&gt;Make Discoverable&lt;/b&gt; below.</item>
        <item>On your Windows PC, open &lt;b&gt;Settings → Bluetooth &amp; devices → Add device&lt;/b&gt;.</item>
        <item>Choose &lt;b&gt;Bluetooth&lt;/b&gt; and wait for &lt;b&gt;TabletHID&lt;/b&gt; to appear.</item>
        <item>Click it to pair — no PIN required.</item>
        <item>Once connected, tap &lt;b&gt;Enter Gamepad&lt;/b&gt; below.</item>
    </string-array>
    <string-array name="instructions_macos_mouse">
        <item>Tap &lt;b&gt;Make Discoverable&lt;/b&gt; below.</item>
        <item>On your Mac, open &lt;b&gt;System Settings → Bluetooth&lt;/b&gt;.</item>
        <item>Wait for &lt;b&gt;TabletHID&lt;/b&gt; to appear in the device list.</item>
        <item>Click &lt;b&gt;Connect&lt;/b&gt; — no PIN required.</item>
        <item>Once connected, tap &lt;b&gt;Enter Touch Mouse&lt;/b&gt; below.</item>
    </string-array>
    <string-array name="instructions_macos_gamepad">
        <item>Tap &lt;b&gt;Make Discoverable&lt;/b&gt; below.</item>
        <item>On your Mac, open &lt;b&gt;System Settings → Bluetooth&lt;/b&gt;.</item>
        <item>Wait for &lt;b&gt;TabletHID&lt;/b&gt; to appear in the device list.</item>
        <item>Click &lt;b&gt;Connect&lt;/b&gt; — no PIN required.</item>
        <item>Once connected, tap &lt;b&gt;Enter Gamepad&lt;/b&gt; below.</item>
    </string-array>

