<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon background — 108×108dp viewport.
    Dark navy radial gradient with a subtle centred glow, echoing the in-app
    gamepad/touch-mouse dark theme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark navy base with centred blue glow -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="62"
                android:startColor="#1C3058"
                android:endColor="#060C18" />
        </aapt:attr>
    </path>

    <!-- Subtle mid-ring brightening -->
    <path android:pathData="M54,54 m-26,0 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="26"
                android:startColor="#0D2040"
                android:endColor="#060C18" />
        </aapt:attr>
    </path>

    <!-- Faint circular ring for depth -->
    <path
        android:pathData="M54,54 m-36,0 a36,36 0 1,0 72,0 a36,36 0 1,0 -72,0 Z
                          M54,54 m-34,0 a34,34 0 1,0 68,0 a34,34 0 1,0 -68,0 Z"
        android:fillColor="#0A2040"
        android:fillType="evenOdd" />

</vector>
